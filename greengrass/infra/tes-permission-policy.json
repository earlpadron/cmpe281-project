{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3DataLakeReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:HeadBucket"
      ],
      "Resource": [
        "arn:aws:s3:::cmpe281-shared-benchmark-data-ep-v2",
        "arn:aws:s3:::cmpe281-shared-benchmark-data-ep-v2/*"
      ]
    },
    {
      "Sid": "S3ArtifactBucketRead",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::__ARTIFACT_BUCKET__",
        "arn:aws:s3:::__ARTIFACT_BUCKET__/*"
      ]
    },
    {
      "Sid": "InvokeCloudResizeLambda",
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction"
      ],
      "Resource": [
        "arn:aws:lambda:us-east-1:*:function:cmpe281-shared-image-resizer"
      ]
    },
    {
      "Sid": "GreengrassRuntimeLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
